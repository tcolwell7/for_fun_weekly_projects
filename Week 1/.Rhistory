# Function to read an ODS file, clean it, and extract metadata
read_ods <- function(file_path) {
# Read the ODS file from sheet "Table_1", skipping first 3 rows
df <- read_ods(
path = file_path,
sheet = "Table_1",
skip = 3
)
df <- df %>%
clean_names() %>%                     # Standardise column names
mutate(
source_file = basename(file_path),  # Store original filename
year = str_extract(source_file, "\\d{4}") %>% as.integer()
)
return(df)
}
